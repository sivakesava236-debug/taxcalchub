<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Taxora — Intelligent Tax Dashboard FY 2025-26</title>
<meta name="description" content="Taxora — a futuristic AI-style Indian Income Tax dashboard for FY 2025-26. Visualize salary flow, compare regimes, and improve your tax efficiency." />
<link rel="canonical" href="https://taxcalchub.lovable.app/" />
<!-- Google Search Console verification (manual HTML tag method). Replace the content value with the token Google gives you in Search Console → Add property → HTML tag. -->
<meta name="google-site-verification" content="REPLACE_WITH_YOUR_GSC_TOKEN" />
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
/* ---------- Design tokens ---------- */
:root{
  --bg-0:#0a0612;
  --bg-1:#120a1f;
  --bg-2:#1c1230;
  --ink:#f5ecdc;
  --ink-dim:#b59fc7;
  --line:rgba(255,220,180,0.08);
  --glass:rgba(255,220,180,0.04);
  --glass-2:rgba(255,220,180,0.08);
  --accent:#f5b54a;
  --accent-2:#c084fc;
  --accent-3:#ff7a59;
  --warn:#ffb454;
  --danger:#ff5d73;
  --good:#5cf2a8;
  --grad: linear-gradient(135deg,#c084fc 0%,#f5b54a 50%,#ff7a59 100%);
  --grad-2: linear-gradient(135deg,#ff7a59,#c084fc);
  --shadow: 0 30px 80px -30px rgba(192,132,252,.35),0 8px 24px -8px rgba(0,0,0,.6);
  --radius: 22px;
  --radius-sm: 14px;
}
html[data-theme="light"]{
  --bg-0:#eef1fb; --bg-1:#f6f8ff; --bg-2:#ffffff;
  --ink:#0e1230; --ink-dim:#4b5176;
  --line:rgba(10,20,60,0.08);
  --glass:rgba(255,255,255,0.55); --glass-2:rgba(255,255,255,0.75);
  --shadow: 0 30px 80px -30px rgba(80,90,200,.25),0 8px 24px -8px rgba(0,0,0,.08);
}

*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--bg-0);color:var(--ink);font-family:'Space Grotesk',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
body{min-height:100vh;overflow-x:hidden}

/* Animated background */
.bg-orbs{position:fixed;inset:0;z-index:-1;overflow:hidden;pointer-events:none}
.bg-orbs::before,.bg-orbs::after,.bg-orbs span{
  content:"";position:absolute;border-radius:50%;filter:blur(80px);opacity:.55;
  animation: float 18s ease-in-out infinite;
}
.bg-orbs::before{width:520px;height:520px;background:#c084fc;top:-160px;left:-120px}
.bg-orbs::after{width:600px;height:600px;background:#ff7a59;bottom:-220px;right:-160px;animation-delay:-6s}
.bg-orbs span{width:420px;height:420px;background:#f5b54a;top:40%;left:55%;animation-delay:-12s;opacity:.3}
@keyframes float{0%,100%{transform:translate(0,0) scale(1)}50%{transform:translate(40px,-30px) scale(1.08)}}
.grid-overlay{position:fixed;inset:0;z-index:-1;background-image:linear-gradient(var(--line) 1px,transparent 1px),linear-gradient(90deg,var(--line) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse at center,#000 30%,transparent 75%);opacity:.5}

/* Layout shell */
.app{display:grid;grid-template-columns:260px 1fr;min-height:100vh}
.sidebar{position:sticky;top:0;height:100vh;padding:24px 18px;border-right:1px solid var(--line);background:linear-gradient(180deg,var(--glass),transparent);backdrop-filter: blur(18px)}
.brand{display:flex;align-items:center;gap:12px;margin-bottom:28px}
.brand-logo{width:42px;height:42px;border-radius:12px;background:var(--grad);position:relative;box-shadow:0 10px 30px -10px rgba(122,162,255,.6)}
.brand-logo::after{content:"₹";position:absolute;inset:0;display:grid;place-items:center;color:#0b1024;font-weight:700;font-size:22px}
.brand-name{font-size:22px;font-weight:700;letter-spacing:.5px}
.brand-tag{font-size:11px;color:var(--ink-dim);letter-spacing:3px;text-transform:uppercase}
.nav{display:flex;flex-direction:column;gap:6px;margin-top:10px}
.nav a{display:flex;align-items:center;gap:12px;padding:11px 14px;color:var(--ink-dim);text-decoration:none;border-radius:12px;font-size:14px;font-weight:500;transition:.25s}
.nav a:hover,.nav a.active{background:var(--glass-2);color:var(--ink);transform:translateX(2px)}
.nav .dot{width:6px;height:6px;border-radius:50%;background:var(--accent)}
.side-foot{position:absolute;bottom:20px;left:18px;right:18px;font-size:11px;color:var(--ink-dim);line-height:1.6}

.main{padding:28px 36px 60px;max-width:100%}
.topbar{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:24px;flex-wrap:wrap}
.topbar h1{margin:0;font-size:28px;font-weight:600;letter-spacing:-.5px}
.topbar h1 span{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
.topbar .subtitle{color:var(--ink-dim);font-size:13px;margin-top:4px}
.toolbar{display:flex;gap:10px;flex-wrap:wrap}
.chip{display:inline-flex;align-items:center;gap:8px;padding:9px 14px;border-radius:999px;border:1px solid var(--line);background:var(--glass);color:var(--ink);font-size:13px;cursor:pointer;transition:.2s;font-family:inherit}
.chip:hover{border-color:var(--accent-2);transform:translateY(-1px)}
.chip.solid{background:var(--grad);color:#0b1024;border:none;font-weight:600}
.chip .pulse{width:8px;height:8px;border-radius:50%;background:var(--good);box-shadow:0 0 0 0 rgba(92,242,168,.7);animation:pulse 2s infinite}
@keyframes pulse{70%{box-shadow:0 0 0 10px rgba(92,242,168,0)}100%{box-shadow:0 0 0 0 rgba(92,242,168,0)}}

/* Grid */
.grid{display:grid;gap:20px}
.cols-12{grid-template-columns:repeat(12,1fr)}
.span-4{grid-column:span 4}.span-3{grid-column:span 3}.span-5{grid-column:span 5}.span-6{grid-column:span 6}.span-7{grid-column:span 7}.span-8{grid-column:span 8}.span-12{grid-column:span 12}

/* Card */
.card{background:var(--glass);border:1px solid var(--line);border-radius:var(--radius);padding:22px;backdrop-filter: blur(18px);box-shadow:var(--shadow);position:relative;overflow:hidden}
.card.glow::before{content:"";position:absolute;inset:-1px;border-radius:inherit;padding:1px;background:var(--grad);-webkit-mask:linear-gradient(#000 0 0) content-box,linear-gradient(#000 0 0);-webkit-mask-composite:xor;mask-composite:exclude;opacity:.4;pointer-events:none}
.card h3{margin:0 0 4px;font-size:14px;font-weight:600;letter-spacing:.3px;color:var(--ink-dim);text-transform:uppercase}
.card .big{font-size:30px;font-weight:700;letter-spacing:-.5px;margin-top:6px;font-family:'JetBrains Mono',monospace}
.card .sub{color:var(--ink-dim);font-size:12px;margin-top:6px}
.card .delta{display:inline-block;margin-top:8px;font-size:12px;padding:4px 9px;border-radius:999px;background:rgba(124,249,212,.12);color:var(--accent);border:1px solid rgba(124,249,212,.25)}
.card .delta.bad{background:rgba(255,93,115,.12);color:var(--danger);border-color:rgba(255,93,115,.25)}

/* Inputs */
.field{margin-bottom:14px}
.field label{display:flex;justify-content:space-between;font-size:12px;color:var(--ink-dim);margin-bottom:6px;letter-spacing:.3px}
.field label .val{color:var(--ink);font-family:'JetBrains Mono',monospace;font-weight:600}
.field input[type=number],.field select{width:100%;background:var(--bg-2);border:1px solid var(--line);color:var(--ink);padding:11px 14px;border-radius:12px;font-family:inherit;font-size:14px;outline:none;transition:.2s}
.field input[type=number]:focus,.field select:focus{border-color:var(--accent-2);box-shadow:0 0 0 4px rgba(122,162,255,.15)}
.field input[type=range]{-webkit-appearance:none;width:100%;height:6px;border-radius:6px;background:linear-gradient(90deg,var(--accent-2),var(--accent));outline:none;margin-top:6px}
.field input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;border-radius:50%;background:#fff;border:3px solid var(--accent-2);cursor:pointer;box-shadow:0 4px 12px rgba(0,0,0,.4)}
.seg{display:flex;background:var(--bg-2);border:1px solid var(--line);border-radius:12px;padding:4px;gap:4px}
.seg button{flex:1;padding:9px 12px;background:transparent;border:none;color:var(--ink-dim);font-family:inherit;font-size:13px;border-radius:9px;cursor:pointer;transition:.2s;font-weight:500}
.seg button.active{background:var(--grad);color:#0b1024;font-weight:600}

/* Sections */
.section-title{display:flex;align-items:center;gap:12px;margin:36px 0 16px}
.section-title h2{margin:0;font-size:20px;font-weight:600;letter-spacing:-.2px}
.section-title .line{flex:1;height:1px;background:linear-gradient(90deg,var(--line),transparent)}
.section-title .tag{font-size:10px;color:var(--accent);letter-spacing:3px;text-transform:uppercase;padding:3px 8px;border:1px solid rgba(124,249,212,.3);border-radius:999px}

/* Flow */
.flow{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;margin-top:14px}
.flow-node{text-align:center;padding:18px 10px;border-radius:16px;border:1px solid var(--line);background:var(--glass-2);position:relative;transition:.3s}
.flow-node:hover{transform:translateY(-4px);border-color:var(--accent-2)}
.flow-node .ico{font-size:22px;margin-bottom:6px}
.flow-node .lbl{font-size:11px;color:var(--ink-dim);text-transform:uppercase;letter-spacing:1.5px}
.flow-node .amt{font-size:18px;font-weight:700;font-family:'JetBrains Mono',monospace;margin-top:4px}
.flow-node .pct{font-size:11px;color:var(--accent);margin-top:2px;font-weight:600}

/* Score ring */
.score-wrap{display:flex;align-items:center;gap:24px}
.ring{position:relative;width:160px;height:160px;flex-shrink:0}
.ring svg{transform:rotate(-90deg)}
.ring .num{position:absolute;inset:0;display:grid;place-items:center;font-size:38px;font-weight:700;font-family:'JetBrains Mono',monospace}
.ring .num small{display:block;font-size:11px;color:var(--ink-dim);letter-spacing:2px;text-transform:uppercase;font-weight:500;margin-top:2px}

/* Battle */
.battle{display:grid;grid-template-columns:1fr auto 1fr;gap:20px;align-items:center;margin-top:14px}
.regime-card{padding:22px;border-radius:18px;border:1px solid var(--line);background:var(--bg-2);transition:.3s;position:relative}
.regime-card.winner{border-color:var(--accent);box-shadow:0 0 0 1px var(--accent),0 20px 60px -20px rgba(124,249,212,.4)}
.regime-card .name{font-size:14px;color:var(--ink-dim);text-transform:uppercase;letter-spacing:2px}
.regime-card .tax{font-size:32px;font-weight:700;font-family:'JetBrains Mono',monospace;margin-top:6px}
.regime-card .meta{font-size:12px;color:var(--ink-dim);margin-top:8px}
.regime-card .badge{position:absolute;top:-12px;right:14px;padding:4px 10px;font-size:11px;font-weight:600;border-radius:999px;background:var(--grad);color:#0b1024;letter-spacing:1px}
.vs{font-size:22px;font-weight:700;font-family:'JetBrains Mono',monospace;color:var(--ink-dim);text-align:center}

/* AI panel */
.ai-list{display:flex;flex-direction:column;gap:10px;margin-top:12px}
.ai-item{display:flex;gap:12px;padding:14px;border-radius:14px;background:var(--bg-2);border:1px solid var(--line);transition:.2s}
.ai-item:hover{border-color:var(--accent-2);transform:translateX(3px)}
.ai-item .av{width:34px;height:34px;border-radius:10px;background:var(--grad-2);display:grid;place-items:center;flex-shrink:0;font-size:16px}
.ai-item p{margin:0;font-size:13px;line-height:1.55}
.ai-item .who{font-size:10px;color:var(--accent);letter-spacing:1.5px;text-transform:uppercase;font-weight:600;margin-bottom:3px;display:block}

/* Health meter */
.meter{height:14px;background:var(--bg-2);border-radius:999px;overflow:hidden;border:1px solid var(--line);position:relative}
.meter-fill{height:100%;background:linear-gradient(90deg,var(--good),var(--warn) 60%,var(--danger));transition:width 1s cubic-bezier(.22,1,.36,1);position:relative}
.meter-ticks{display:flex;justify-content:space-between;font-size:11px;color:var(--ink-dim);margin-top:8px}

/* Steps explain */
.steps{counter-reset:step;display:flex;flex-direction:column;gap:10px;margin-top:14px}
.step{display:flex;gap:14px;padding:14px 16px;border-radius:14px;background:var(--bg-2);border:1px solid var(--line);cursor:pointer;transition:.25s}
.step:hover{border-color:var(--accent-2)}
.step::before{counter-increment:step;content:counter(step);width:30px;height:30px;border-radius:10px;background:var(--grad);color:#0b1024;display:grid;place-items:center;font-weight:700;flex-shrink:0;font-family:'JetBrains Mono',monospace}
.step .body{flex:1}
.step .body h4{margin:0;font-size:14px;font-weight:600}
.step .body p{margin:4px 0 0;font-size:13px;color:var(--ink-dim);line-height:1.5}
.step .body .amt{font-family:'JetBrains Mono',monospace;color:var(--accent);font-weight:600}
.step .details{display:none;margin-top:10px;padding-top:10px;border-top:1px dashed var(--line);font-size:12px;color:var(--ink-dim);line-height:1.6}
.step.open .details{display:block}

/* Slab table */
.slab-table{width:100%;border-collapse:collapse;margin-top:14px;font-size:13px}
.slab-table th,.slab-table td{padding:11px 14px;text-align:left;border-bottom:1px solid var(--line);font-family:'JetBrains Mono',monospace}
.slab-table th{font-size:11px;letter-spacing:1px;color:var(--ink-dim);text-transform:uppercase;font-family:'Space Grotesk',sans-serif;font-weight:600}
.slab-table tr:hover td{background:var(--glass-2)}
.slab-table .tax-cell{color:var(--accent);font-weight:600}

/* Mini tools */
.tools-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:16px;margin-top:14px}
.tool{padding:18px;border-radius:16px;background:var(--bg-2);border:1px solid var(--line)}
.tool h4{margin:0 0 6px;font-size:14px;display:flex;align-items:center;gap:8px}
.tool h4 .ico{width:28px;height:28px;border-radius:8px;background:var(--grad-2);display:grid;place-items:center;font-size:14px}
.tool .desc{font-size:11.5px;color:var(--ink-dim);line-height:1.5;margin:0 0 12px;padding-bottom:10px;border-bottom:1px dashed var(--line)}
.tool .row{display:flex;gap:8px;margin-bottom:8px}
.tool .col{flex:1;display:flex;flex-direction:column;gap:4px;min-width:0}
.tool .col label{font-size:10px;letter-spacing:.8px;text-transform:uppercase;color:var(--ink-dim);font-weight:600}
.tool input,.tool select{width:100%;background:var(--bg-1);border:1px solid var(--line);color:var(--ink);padding:8px 10px;border-radius:9px;font-family:inherit;font-size:13px;outline:none;min-width:0;box-sizing:border-box}
.tool .out{margin-top:10px;padding:10px 12px;border-radius:10px;background:var(--bg-1);border:1px dashed var(--line);font-family:'JetBrains Mono',monospace;font-size:14px;font-weight:600;color:var(--accent)}

/* FAQ */
.faq details{padding:14px 18px;border-radius:14px;background:var(--bg-2);border:1px solid var(--line);margin-bottom:8px;cursor:pointer}
.faq details[open]{border-color:var(--accent-2)}
.faq summary{font-weight:600;font-size:14px;list-style:none;display:flex;justify-content:space-between;align-items:center}
.faq summary::after{content:"+";font-size:20px;color:var(--accent);transition:.3s}
.faq details[open] summary::after{transform:rotate(45deg)}
.faq p{margin:10px 0 0;font-size:13px;color:var(--ink-dim);line-height:1.6}

/* Timeline */
.timeline{display:grid;grid-template-columns:repeat(12,1fr);gap:6px;margin-top:14px}
.tl-bar{height:80px;background:var(--bg-2);border:1px solid var(--line);border-radius:10px;position:relative;display:flex;flex-direction:column;justify-content:flex-end;padding:6px;overflow:hidden;transition:.3s;cursor:pointer}
.tl-bar:hover{transform:translateY(-3px);border-color:var(--accent-2)}
.tl-bar .fill{position:absolute;left:0;right:0;bottom:0;background:linear-gradient(180deg,var(--accent-2),var(--accent));border-radius:0 0 9px 9px;transition:height 1s cubic-bezier(.22,1,.36,1)}
.tl-bar .m{font-size:10px;color:var(--ink-dim);text-align:center;position:relative;z-index:1}
.tl-bar .v{font-size:10px;font-weight:600;text-align:center;position:relative;z-index:1;font-family:'JetBrains Mono',monospace}

/* Footer */
.footer{margin-top:50px;padding:24px;text-align:center;font-size:12px;color:var(--ink-dim);border-top:1px solid var(--line)}
.disclaimer{margin-top:20px;padding:14px 18px;background:rgba(255,180,84,.08);border:1px solid rgba(255,180,84,.25);border-radius:14px;font-size:12px;color:var(--warn);text-align:center}

/* Responsive */
@media (max-width:1024px){
  .app{grid-template-columns:1fr}
  .sidebar{position:relative;height:auto;padding:18px}
  .sidebar .nav{flex-direction:row;flex-wrap:wrap;overflow-x:auto}
  .side-foot{display:none}
  .span-3,.span-4,.span-5{grid-column:span 6}
  .span-6,.span-7,.span-8{grid-column:span 12}
  .main{padding:20px}
  .flow{grid-template-columns:repeat(2,1fr)}
  .battle{grid-template-columns:1fr;text-align:center}
  .vs{padding:6px}
}
@media (max-width:768px){
  .span-3,.span-4,.span-5,.span-6,.span-7,.span-8{grid-column:span 12}
  .topbar h1{font-size:22px}
  .topbar .subtitle{font-size:12px}
  .card .big{font-size:24px}
  .card{padding:16px}
  .main{padding:16px}
  .flow{grid-template-columns:repeat(2,1fr)}
  .flow-node .amt{font-size:15px}
  .score-wrap{flex-direction:column;align-items:flex-start;gap:16px}
  .ring{width:140px;height:140px}
  .ring .num{font-size:32px}
  .timeline{grid-template-columns:repeat(6,1fr)}
  .tools-grid{grid-template-columns:1fr}
  .tool .row{flex-direction:column;gap:10px}
  .slab-table{font-size:12px;display:block;overflow-x:auto;white-space:nowrap}
  .sidebar{padding:14px}
  .sidebar .nav{gap:4px}
  .sidebar .nav a{padding:8px 10px;font-size:13px}
  .brand-name{font-size:18px}
  .section-title h2{font-size:17px}
  /* Stack inline 2-col input grids into single column */
  #inputs > div > div[style*="grid-template-columns:1fr 1fr"]{grid-template-columns:1fr !important}
}
@media (max-width:420px){
  .flow{grid-template-columns:1fr}
  .timeline{grid-template-columns:repeat(4,1fr)}
}

/* Animation reveal */
.reveal{opacity:0;transform:translateY(20px);animation:rise .8s cubic-bezier(.22,1,.36,1) forwards}
@keyframes rise{to{opacity:1;transform:translateY(0)}}
.reveal:nth-child(2){animation-delay:.08s}
.reveal:nth-child(3){animation-delay:.16s}
.reveal:nth-child(4){animation-delay:.24s}
.reveal:nth-child(5){animation-delay:.32s}

/* Tooltip */
[data-tip]{position:relative;cursor:help;border-bottom:1px dotted var(--ink-dim)}
[data-tip]:hover::after{content:attr(data-tip);position:absolute;bottom:130%;left:50%;transform:translateX(-50%);background:var(--bg-2);color:var(--ink);padding:6px 10px;border-radius:8px;font-size:11px;white-space:nowrap;border:1px solid var(--line);z-index:10}

::-webkit-scrollbar{width:8px;height:8px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--glass-2);border-radius:8px}
/* Walkthrough Tour */
.tour-backdrop{position:fixed;inset:0;background:rgba(4,8,18,.72);backdrop-filter:blur(6px);z-index:998;opacity:0;pointer-events:none;transition:opacity .3s}
.tour-backdrop.on{opacity:1;pointer-events:auto}
.tour-spot{position:absolute;border-radius:18px;box-shadow:0 0 0 9999px rgba(4,8,18,.72),0 0 0 3px #7cf9d4,0 0 40px 6px rgba(124,249,212,.45);transition:all .45s cubic-bezier(.5,.1,.2,1);pointer-events:none}
.tour-pop{position:absolute;max-width:340px;background:linear-gradient(160deg,rgba(30,40,70,.96),rgba(20,24,45,.96));border:1px solid rgba(255,255,255,.12);border-radius:16px;padding:18px 18px 14px;color:#fff;z-index:1000;box-shadow:0 22px 50px rgba(0,0,0,.5);transition:all .4s cubic-bezier(.5,.1,.2,1)}
.tour-pop .step{font-size:11px;letter-spacing:2px;color:#7cf9d4;text-transform:uppercase;font-weight:700}
.tour-pop h4{margin:6px 0 6px;font-size:18px;font-weight:700}
.tour-pop p{font-size:13px;line-height:1.5;color:rgba(255,255,255,.78);margin:0 0 14px}
.tour-pop .row{display:flex;gap:8px;align-items:center;justify-content:space-between}
.tour-pop .dots{display:flex;gap:6px}
.tour-pop .dots i{width:7px;height:7px;border-radius:50%;background:rgba(255,255,255,.22);display:block}
.tour-pop .dots i.active{background:#7cf9d4;width:18px;border-radius:4px}
.tour-pop button{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.2);padding:7px 14px;border-radius:10px;font-size:12px;cursor:pointer;font-weight:600}
.tour-pop button.primary{background:linear-gradient(135deg,#7aa2ff,#7cf9d4);color:#0a0f1e;border:none}
.tour-pop button:hover{filter:brightness(1.1)}
</style>
</head>
