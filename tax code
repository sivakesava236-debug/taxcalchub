/* ===================== Walkthrough Tour ===================== */
const TOUR_STEPS=[
  {sel:'#inputs',title:'Your Inputs',body:'Adjust salary, deductions and expenses. Every slider instantly recomputes the entire dashboard.'},
  {sel:'#scoreCard',title:'Tax Efficiency Score',body:'A 0–100 grade based on how well you use deductions, your regime choice and your savings rate.'},
  {sel:'#battleCard',title:'Regime Battle',body:'Live head-to-head between the Old and New regimes. The "Smarter Choice" badge picks the one that saves you more tax.'},
  {sel:'#flow',title:'Salary Flow',body:'See exactly where every rupee goes — tax, investments, expenses and savings — visualised as nodes and a pie chart.'},
  {sel:'#timelineCard',title:'Monthly Timeline',body:'Your in-hand income spread across the 12 months of FY 2025–26, with bonus spikes highlighted.'}
];
(function tour(){
  const back=document.createElement('div');back.className='tour-backdrop';
  const spot=document.createElement('div');spot.className='tour-spot';
  const pop=document.createElement('div');pop.className='tour-pop';
  back.appendChild(spot);back.appendChild(pop);document.body.appendChild(back);
  let i=0;
  // ---- Voice narration (Web Speech API) ----
  const synth=window.speechSynthesis;
  let voiceOn=(()=>{try{return localStorage.getItem('taxora_voice')!=='0';}catch(e){return true;}})();
  let voices=[];
  function loadVoices(){voices=synth?synth.getVoices():[];}
  if(synth){loadVoices();synth.onvoiceschanged=loadVoices;}
  function pickVoice(){
    if(!voices.length)return null;
    const prefs=[/en-IN/i,/en-GB/i,/Google.*English/i,/Samantha/i,/en-US/i,/^en/i];
    for(const p of prefs){const v=voices.find(x=>p.test(x.lang)||p.test(x.name));if(v)return v;}
    return voices[0];
  }
  function speak(text){
    if(!synth||!voiceOn)return;
    try{synth.cancel();
      const u=new SpeechSynthesisUtterance(text);
      const v=pickVoice();if(v)u.voice=v;
      u.rate=1;u.pitch=1;u.volume=1;
      synth.speak(u);
    }catch(e){}
  }
  function stopSpeak(){try{synth&&synth.cancel();}catch(e){}}
  function place(){
    const s=TOUR_STEPS[i];const el=document.querySelector(s.sel);if(!el)return next();
    el.scrollIntoView({behavior:'smooth',block:'center'});
    setTimeout(()=>{
      const r=el.getBoundingClientRect();const pad=10;
      const top=r.top+window.scrollY-pad,left=r.left+window.scrollX-pad,w=r.width+pad*2,h=r.height+pad*2;
      spot.style.top=top+'px';spot.style.left=left+'px';spot.style.width=w+'px';spot.style.height=h+'px';
      const dots=TOUR_STEPS.map((_,k)=>`<i class="${k===i?'active':''}"></i>`).join('');
      const vIcon=voiceOn?'🔊':'🔇';
      pop.innerHTML=`<div class="step">Step ${i+1} of ${TOUR_STEPS.length}</div><h4>${s.title}</h4><p>${s.body}</p><div class="row"><div class="dots">${dots}</div><div style="display:flex;gap:6px"><button id="tVoice" title="Toggle voice">${vIcon}</button><button id="tSkip">Skip</button><button id="tNext" class="primary">${i===TOUR_STEPS.length-1?'Finish':'Next →'}</button></div></div>`;
      const vw=window.innerWidth,vh=window.innerHeight;const pw=340,ph=pop.offsetHeight||180;
      let py=r.bottom+window.scrollY+14;let px=r.left+window.scrollX;
      if(r.bottom+ph+30>vh){py=r.top+window.scrollY-ph-14;}
      if(px+pw>window.scrollX+vw-16)px=window.scrollX+vw-pw-16;
      if(px<window.scrollX+16)px=window.scrollX+16;
      if(py<window.scrollY+16)py=window.scrollY+16;
      pop.style.top=py+'px';pop.style.left=px+'px';
      document.getElementById('tNext').onclick=next;
      document.getElementById('tSkip').onclick=end;
      document.getElementById('tVoice').onclick=()=>{
        voiceOn=!voiceOn;
        try{localStorage.setItem('taxora_voice',voiceOn?'1':'0');}catch(e){}
        document.getElementById('tVoice').textContent=voiceOn?'🔊':'🔇';
        if(voiceOn)speak(s.title+'. '+s.body);else stopSpeak();
        syncVoiceBtn();
      };
      speak(s.title+'. '+s.body);
    },380);
  }
  function next(){stopSpeak();i++;if(i>=TOUR_STEPS.length)return end();place();}
  function end(){stopSpeak();back.classList.remove('on');setTimeout(()=>{i=0;},400);try{localStorage.setItem('taxora_tour','1');}catch(e){}}
  function start(){i=0;back.classList.add('on');place();}
  function syncVoiceBtn(){const b=document.getElementById('voiceBtn');if(b)b.textContent=(voiceOn?'🔊':'🔇')+' Voice';}
  document.getElementById('tourBtn').onclick=start;
  // Global voice toggle chip
  const vb=document.getElementById('voiceBtn');
  if(vb){vb.textContent=(voiceOn?'🔊':'🔇')+' Voice';
    vb.onclick=()=>{voiceOn=!voiceOn;try{localStorage.setItem('taxora_voice',voiceOn?'1':'0');}catch(e){}
      syncVoiceBtn();if(!voiceOn)stopSpeak();
      else{const intro="Welcome to Taxora. Your futuristic Indian income tax dashboard for financial year 2025 to 26.";speak(intro);}
    };
  }
  window.addEventListener('keydown',e=>{if(!back.classList.contains('on'))return;if(e.key==='Escape')end();if(e.key==='ArrowRight'||e.key==='Enter')next();});
  back.addEventListener('click',e=>{if(e.target===back)end();});
  window.addEventListener('beforeunload',stopSpeak);
  setTimeout(()=>{try{if(!localStorage.getItem('taxora_tour'))start();}catch(e){}},900);
})();

/* ===================== Boot ===================== */
window.addEventListener('load',()=>{
  initCharts();render();emi();sip();gst();cur();salc();ig();
});
</script>

<script>
/* ============ SEO Health Widget ============ */
(function(){
  const listEl = document.getElementById('seoList');
  const alertsEl = document.getElementById('seoAlerts');
  const scoreEl = document.getElementById('seoScore');
  const fillEl = document.getElementById('seoFill');
  const btn = document.getElementById('seoRefresh');
  if(!listEl) return;

  const sev = { ok:{c:'#4ade80',i:'✓'}, warn:{c:'#f5b54a',i:'!'}, err:{c:'#ff7a59',i:'✗'} };

  function row(label, status, detail, action){
    const s = sev[status];
    return `<li style="border:1px solid var(--line);border-radius:12px;padding:12px;background:var(--glass)">
      <div style="display:flex;align-items:center;gap:8px">
        <span style="display:inline-flex;width:22px;height:22px;border-radius:50%;background:${s.c}22;color:${s.c};align-items:center;justify-content:center;font-weight:700">${s.i}</span>
        <strong style="font-size:13px">${label}</strong>
      </div>
      <div class="sub" style="margin-top:6px;font-size:12px">${detail}</div>
      ${action?`<div style="margin-top:8px">${action}</div>`:''}
    </li>`;
  }

  async function check(url, opts){
    try{
      const r = await fetch(url, Object.assign({cache:'no-store'}, opts||{}));
      const text = await r.text();
      return { ok:r.ok, status:r.status, text, headers:r.headers };
    }catch(e){ return { ok:false, status:0, text:'', error:String(e) }; }
  }

  async function run(){
    listEl.innerHTML = '<li class="sub" style="padding:8px">Running checks…</li>';
    alertsEl.innerHTML = '';
    const results = [];
    const alerts = [];

    // 1. robots.txt
    const robots = await check('/robots.txt');
    if(robots.ok && /Sitemap:/i.test(robots.text)){
      results.push(['robots.txt reachable & references sitemap','ok','HTTP 200 and contains Sitemap directive.']);
    }else if(robots.ok){
      results.push(['robots.txt missing Sitemap line','warn','Add a "Sitemap:" directive so crawlers find it.']);
      alerts.push(['warn','robots.txt does not advertise your sitemap URL.']);
    }else{
      results.push(['robots.txt unreachable','err',`HTTP ${robots.status}. Crawlers may not know what to index.`]);
      alerts.push(['err','robots.txt could not be fetched.']);
    }
    if(robots.ok && /Disallow:\s*\/\s*$/m.test(robots.text)){
      results.push(['Site is blocking all crawlers','err','robots.txt has "Disallow: /". Remove it to be indexed.']);
      alerts.push(['err','You are blocking all search engines via robots.txt.']);
    }

    // 2. sitemap.xml
    const sm = await check('/sitemap.xml');
    if(sm.ok && /<urlset|<sitemapindex/.test(sm.text)){
      const count = (sm.text.match(/<loc>/g)||[]).length;
      results.push([`sitemap.xml valid (${count} URL${count===1?'':'s'})`,'ok','Submit it inside Google Search Console → Sitemaps.',
        '<a class="chip" href="https://search.google.com/search-console/sitemaps" target="_blank" rel="noopener">Submit in GSC</a>']);
    }else{
      results.push(['sitemap.xml missing or invalid','err',`HTTP ${sm.status}. Generate one at /sitemap.xml.`]);
      alerts.push(['err','sitemap.xml is missing or malformed.']);
    }

    // 3. GSC verification meta
    const ver = document.querySelector('meta[name="google-site-verification"]');
    if(!ver){
      results.push(['Google Search Console not verified','warn','Add a google-site-verification meta tag in <head>.']);
      alerts.push(['warn','GSC verification meta tag is missing.']);
    }else if(/REPLACE_WITH_YOUR_GSC_TOKEN/.test(ver.content)){
      results.push(['GSC meta tag is a placeholder','warn','Paste your token from Search Console → HTML tag method.',
        '<a class="chip" href="https://search.google.com/search-console/welcome" target="_blank" rel="noopener">Get your token</a>']);
      alerts.push(['warn','Replace the placeholder google-site-verification token.']);
    }else{
      results.push(['GSC meta verification tag present','ok','Token: '+ver.content.slice(0,12)+'…']);
    }

    // 4. Title
    const title = document.title || '';
    if(title.length < 10) results.push(['Page title too short','err',`Only ${title.length} chars.`]);
    else if(title.length > 60) results.push(['Page title too long','warn',`${title.length} chars; Google truncates ~60.`]);
    else results.push(['Title length OK','ok',`${title.length} chars.`]);

    // 5. Meta description
    const desc = (document.querySelector('meta[name="description"]')||{}).content || '';
    if(!desc) results.push(['Missing meta description','err','Add <meta name="description"> in <head>.']);
    else if(desc.length < 70) results.push(['Meta description short','warn',`${desc.length} chars; aim for 120–160.`]);
    else if(desc.length > 160) results.push(['Meta description long','warn',`${desc.length} chars; Google truncates ~160.`]);
    else results.push(['Meta description length OK','ok',`${desc.length} chars.`]);

    // 6. Canonical
    const canon = document.querySelector('link[rel="canonical"]');
    results.push(canon
      ? ['Canonical URL set','ok',canon.href]
      : ['Canonical URL missing','warn','Add <link rel="canonical"> to avoid duplicate-content dilution.']);

    // 7. H1
    const h1s = document.querySelectorAll('h1');
    if(h1s.length === 0) results.push(['No H1 on page','err','Every page needs exactly one H1.']);
    else if(h1s.length > 1) results.push([`${h1s.length} H1 tags`,'warn','Use only one H1 per page.']);
    else results.push(['Single H1 present','ok',`"${h1s[0].textContent.trim().slice(0,60)}"`]);

    // 8. Viewport
    results.push(document.querySelector('meta[name="viewport"]')
      ? ['Mobile viewport set','ok','Page is responsive-ready.']
      : ['Viewport meta missing','err','Add <meta name="viewport">.']);

    // 9. Open Graph
    const og = ['og:title','og:description','og:type'].filter(p=>!document.querySelector(`meta[property="${p}"]`));
    results.push(og.length===0
      ? ['Open Graph tags complete','ok','og:title, og:description, og:type all present.']
      : [`Missing OG tags: ${og.join(', ')}`,'warn','Improves link previews on social.']);

    // 10. HTTPS
    results.push(location.protocol === 'https:'
      ? ['HTTPS enabled','ok','Secure connection confirmed.']
      : ['Not served over HTTPS','err','Google penalises non-HTTPS sites.']);

    // 11. JSON-LD
    results.push(document.querySelector('script[type="application/ld+json"]')
      ? ['Structured data found','ok','JSON-LD present on page.']
      : ['No structured data','warn','Add JSON-LD (WebSite, FAQPage, Organization).']);

    // Render
    listEl.innerHTML = results.map(r=>row(r[0],r[1],r[2],r[3])).join('');
    const okCount = results.filter(r=>r[1]==='ok').length;
    const score = Math.round((okCount/results.length)*100);
    scoreEl.textContent = score;
    fillEl.style.width = score+'%';

    alertsEl.innerHTML = alerts.length === 0
      ? `<div class="sub" style="color:#4ade80">No actionable alerts — your SEO basics look healthy.</div>`
      : alerts.map(([lvl,msg])=>{
          const s = sev[lvl];
          return `<div style="border-left:3px solid ${s.c};padding:8px 12px;background:${s.c}11;border-radius:8px;font-size:13px"><strong style="color:${s.c}">${lvl.toUpperCase()}</strong> · ${msg}</div>`;
        }).join('');
  }

  btn && btn.addEventListener('click', run);
  // run after first paint
  setTimeout(run, 600);
})();
</script>
</body>
</html>
