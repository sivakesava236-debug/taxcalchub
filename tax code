<script>
/* ===================== Utilities ===================== */
const $ = id => document.getElementById(id);
const fmt = n => "₹" + Math.round(n).toLocaleString('en-IN');
const pct = (a,b) => b>0 ? (a/b*100) : 0;
document.getElementById('yr').textContent = new Date().getFullYear();

/* ===================== Tax Engine ===================== */
// FY 2025-26 New Regime slabs (post Budget 2025: 0-4L 0%, 4-8 5%, 8-12 10%, 12-16 15%, 16-20 20%, 20-24 25%, 24+ 30%)
const NEW_SLABS = [
  [400000,0],[800000,0.05],[1200000,0.10],[1600000,0.15],
  [2000000,0.20],[2400000,0.25],[Infinity,0.30]
];
// Old regime (below 60)
const OLD_SLABS_DEFAULT = [[250000,0],[500000,0.05],[1000000,0.20],[Infinity,0.30]];
const OLD_SLABS_60 = [[300000,0],[500000,0.05],[1000000,0.20],[Infinity,0.30]];
const OLD_SLABS_80 = [[500000,0],[1000000,0.20],[Infinity,0.30]];

function slabTax(taxable, slabs){
  let tax=0, prev=0, parts=[];
  for(const [limit,rate] of slabs){
    if(taxable<=prev) break;
    const slice = Math.min(taxable,limit)-prev;
    const part = slice*rate;
    tax += part;
    parts.push({from:prev,to:Math.min(taxable,limit),rate,amount:part});
    prev=limit;
    if(taxable<=limit) break;
  }
  return {tax,parts};
}
function surcharge(tax,income){
  let r=0;
  if(income>50000000) r=0.37;
  else if(income>20000000) r=0.25;
  else if(income>10000000) r=0.15;
  else if(income>5000000) r=0.10;
  return tax*r;
}
function calcRegime(regime, inputs){
  const {salary,other,bonus,free,d80c,d80d,hra,hloan,od,age} = inputs;
  const gross = salary+other+bonus+free;
  let taxable, deductions, std;
  if(regime==='new'){
    std = 75000;
    deductions = std;
    taxable = Math.max(0, gross - std);
  } else {
    std = 50000;
    const totalDed = std + d80c + d80d + hra + hloan + od;
    deductions = totalDed;
    taxable = Math.max(0, gross - totalDed);
  }
  const slabs = regime==='new' ? NEW_SLABS : (age==='above80'?OLD_SLABS_80 : age==='60to80'?OLD_SLABS_60 : OLD_SLABS_DEFAULT);
  const {tax:baseTax, parts} = slabTax(taxable, slabs);
  // Rebate 87A
  let rebate=0;
  if(regime==='new' && taxable<=1200000) rebate = Math.min(baseTax, 60000);
  else if(regime==='old' && taxable<=500000) rebate = Math.min(baseTax, 12500);
  const afterRebate = Math.max(0, baseTax - rebate);
  const sur = surcharge(afterRebate, taxable);
  const cess = (afterRebate+sur)*0.04;
  const total = afterRebate+sur+cess;
  return {gross,taxable,deductions,std,baseTax,rebate,surcharge:sur,cess,total,parts,slabs,regime};
}

/* ===================== Charts ===================== */
let pieChart, barChart;
function initCharts(){
  Chart.defaults.color = getComputedStyle(document.body).getPropertyValue('--ink-dim');
  Chart.defaults.font.family = "'Space Grotesk', sans-serif";
  const pCtx = $('pieChart').getContext('2d');
  pieChart = new Chart(pCtx,{type:'doughnut',data:{labels:['Tax','Investments','Expenses','Savings'],datasets:[{data:[1,1,1,1],backgroundColor:['#ff6ec7','#7aa2ff','#ffb454','#7cf9d4'],borderColor:'transparent',borderWidth:0,hoverOffset:14}]},options:{cutout:'68%',plugins:{legend:{position:'bottom',labels:{usePointStyle:true,boxWidth:8,padding:14}}},animation:{animateRotate:true,duration:900}}});
  const bCtx = $('barChart').getContext('2d');
  const grad = bCtx.createLinearGradient(0,0,0,240);
  grad.addColorStop(0,'#7cf9d4');grad.addColorStop(1,'rgba(122,162,255,.2)');
  barChart = new Chart(bCtx,{type:'bar',data:{labels:['Salary','Bonus','Freelance','Other','Deductions'],datasets:[{data:[0,0,0,0,0],backgroundColor:grad,borderRadius:10,borderSkipped:false}]},options:{plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{grid:{color:'rgba(255,255,255,.05)'},ticks:{callback:v=>'₹'+(v/100000).toFixed(0)+'L'}}}}});
}

/* ===================== State ===================== */
let regimePref = 'auto';
function readInputs(){
  return {
    salary:+$('salary').value, other:+$('other').value, bonus:+$('bonus').value, free:+$('free').value,
    d80c:+$('d80c').value, d80d:+$('d80d').value, hra:+$('hra').value, hloan:+$('hloan').value, od:+$('od').value,
    exp:+$('exp').value*12, invMonthly:+$('inv').value, age:$('age').value
  };
}
function updateLabels(i){
  $('lblSalary').textContent=fmt(i.salary);$('lblOther').textContent=fmt(i.other);$('lblBonus').textContent=fmt(i.bonus);
  $('lblFree').textContent=fmt(i.free);$('lbl80c').textContent=fmt(i.d80c);$('lbl80d').textContent=fmt(i.d80d);
  $('lblHra').textContent=fmt(i.hra);$('lblHl').textContent=fmt(i.hloan);$('lblOd').textContent=fmt(i.od);
  $('lblExp').textContent=fmt(i.exp/12);$('lblInv').textContent=fmt(i.invMonthly);
}

/* ===================== Main render ===================== */
function render(){
  const i = readInputs();
  updateLabels(i);
  const oldR = calcRegime('old', i);
  const newR = calcRegime('new', i);
  const chosen = regimePref==='auto' ? (newR.total<=oldR.total?newR:oldR) : (regimePref==='new'?newR:oldR);

  // KPIs
  $('kpiTax').textContent = fmt(chosen.total);
  $('kpiTaxDelta').textContent = `Auto-picked: ${chosen.regime==='new'?'New':'Old'} regime`;
  $('kpiTaxDelta').className = 'delta';
  $('kpiTaxSub').textContent = `Effective rate ${pct(chosen.total,oldR.gross).toFixed(1)}% of gross`;

  const inHand = oldR.gross - chosen.total;
  $('kpiHand').textContent = fmt(inHand);
  $('kpiHandPct').textContent = `${pct(inHand,oldR.gross).toFixed(1)}% of gross`;
  $('kpiMonthly').textContent = `Monthly ~ ${fmt(inHand/12)}`;

  // Flow
  const annualInv = i.invMonthly*12;
  const expenses = i.exp;
  const savings = Math.max(0, inHand - annualInv - expenses);
  $('fGross').textContent=fmt(oldR.gross);
  $('fTax').textContent=fmt(chosen.total);$('fTaxPct').textContent=pct(chosen.total,oldR.gross).toFixed(1)+'%';
  $('fInv').textContent=fmt(annualInv);$('fInvPct').textContent=pct(annualInv,oldR.gross).toFixed(1)+'%';
  $('fExp').textContent=fmt(expenses);$('fExpPct').textContent=pct(expenses,oldR.gross).toFixed(1)+'%';
  $('fSav').textContent=fmt(savings);$('fSavPct').textContent=pct(savings,oldR.gross).toFixed(1)+'%';

  // Pie + Bar
  pieChart.data.datasets[0].data=[chosen.total,annualInv,expenses,savings];pieChart.update();
  barChart.data.datasets[0].data=[i.salary,i.bonus,i.free,i.other,chosen.regime==='new'?75000:(50000+i.d80c+i.d80d+i.hra+i.hloan+i.od)];barChart.update();

  // Regime battle
  $('oldTax').textContent=fmt(oldR.total);
  $('newTax').textContent=fmt(newR.total);
  $('oldMeta').textContent=`Taxable ${fmt(oldR.taxable)} · Deductions ${fmt(oldR.deductions)}`;
  $('newMeta').textContent=`Taxable ${fmt(newR.taxable)} · Std ded ₹75,000`;
  $('oldCard').classList.toggle('winner', oldR.total<=newR.total);
  $('newCard').classList.toggle('winner', newR.total<oldR.total);
  document.querySelectorAll('.regime-card .badge').forEach(b=>b.remove());
  const winner = oldR.total<=newR.total ? $('oldCard') : $('newCard');
  const badge = document.createElement('div');badge.className='badge';badge.textContent='SMARTER';winner.appendChild(badge);
  const diff = Math.abs(oldR.total-newR.total);
  $('regimeVerdict').innerHTML = diff<1 ? 'Both regimes are practically equal for your profile.' :
    `<strong>${oldR.total<newR.total?'Old':'New'} regime</strong> saves you <strong style="color:var(--accent)">${fmt(diff)}</strong> (${pct(diff,oldR.gross).toFixed(2)}% of gross).`;

  // Score
  let score = 50;
  score += Math.min(20, (i.d80c/150000)*20);
  score += Math.min(10, (i.d80d/25000)*10);
  score += Math.min(15, (annualInv/oldR.gross)*60);
  score -= Math.min(20, pct(chosen.total,oldR.gross)*0.7);
  score = Math.max(5, Math.min(99, Math.round(score)));
  $('scoreNum').textContent = score;
  const ring = $('ringFg'); const circ = 2*Math.PI*68;
  ring.style.strokeDashoffset = circ - (circ*score/100);
  $('scoreLabel').textContent = score>=75?'Excellent':score>=55?'Good':score>=35?'Average':'Needs work';
  $('scoreLabel').style.color = score>=75?'var(--good)':score>=55?'var(--accent)':score>=35?'var(--warn)':'var(--danger)';

  // Health meter
  const burden = pct(chosen.total, oldR.gross);
  $('healthFill').style.width = Math.min(100, burden*5)+'%';
  $('healthMsg').textContent = burden<8 ? 'Light burden — you have great room to invest more.' : burden<18 ? 'Moderate burden — consider 80C / NPS top-ups.' : 'Heavy burden — explore old regime + max deductions.';

  // AI suggestions
  const tips = [];
  if(i.d80c<150000) tips.push({who:'80C Coach',ico:'💡',t:`Investing ₹${(150000-i.d80c).toLocaleString('en-IN')} more in ELSS/PPF saves up to ₹${Math.round((150000-i.d80c)*0.3).toLocaleString('en-IN')} in tax under the old regime.`});
  if(i.d80d<25000) tips.push({who:'Health',ico:'🛡️',t:`Buy a ₹${(25000-i.d80d).toLocaleString('en-IN')} health insurance plan — premium qualifies under 80D.`});
  if(oldR.total<newR.total && regimePref==='new') tips.push({who:'Regime',ico:'🔀',t:`Old regime saves you ${fmt(newR.total-oldR.total)} — switch when filing.`});
  if(newR.total<oldR.total && regimePref==='old') tips.push({who:'Regime',ico:'🔀',t:`New regime is leaner by ${fmt(oldR.total-newR.total)} — consider switching.`});
  if(annualInv/oldR.gross<0.2) tips.push({who:'Wealth',ico:'📈',t:`Your investment rate is ${(annualInv/oldR.gross*100).toFixed(1)}%. Aim for 20%+ to compound aggressively.`});
  if(i.hra===0 && i.salary>500000) tips.push({who:'HRA',ico:'🏠',t:`Living on rent? Claiming HRA exemption can shave a chunk off the old regime.`});
  if(tips.length===0) tips.push({who:'Coach',ico:'🌟',t:`You're optimised. Consider NPS Tier-1 for an extra ₹50,000 deduction (80CCD-1B).`});
  $('aiList').innerHTML = tips.map(t=>`<div class="ai-item"><div class="av">${t.ico}</div><div><span class="who">${t.who}</span><p>${t.t}</p></div></div>`).join('');

  // Wealth
  const r=0.12/12;
  function fv(n){const m=n*12;return i.invMonthly*((Math.pow(1+r,m)-1)/r)*(1+r)}
  $('w5').textContent=fmt(fv(5));$('w10').textContent=fmt(fv(10));$('w20').textContent=fmt(fv(20));

  // Steps
  const stepData = [
    {h:'Gross Income Assembled',p:`Salary ${fmt(i.salary)} + Bonus ${fmt(i.bonus)} + Freelance ${fmt(i.free)} + Other ${fmt(i.other)} = <span class="amt">${fmt(oldR.gross)}</span>`,d:'Every taxable income head is summed before any deduction is applied.'},
    {h:'Standard Deduction',p:`A flat <span class="amt">${fmt(chosen.std)}</span> is auto-deducted under the ${chosen.regime} regime.`,d:'Standard deduction was raised to ₹75,000 in the new regime from FY 2024-25.'},
    {h:'Deductions Applied',p: chosen.regime==='old' ? `80C ${fmt(i.d80c)} · 80D ${fmt(i.d80d)} · HRA ${fmt(i.hra)} · Home Loan ${fmt(i.hloan)} · Other ${fmt(i.od)} = <span class="amt">${fmt(chosen.deductions-chosen.std)}</span> extra.` : `New regime ignores 80C/80D etc. Only standard deduction applies.`,d:'The old regime rewards documented investments and spending; the new regime offers wider slabs instead.'},
    {h:'Taxable Income',p:`Gross − Deductions = <span class="amt">${fmt(chosen.taxable)}</span>`,d:'This is the figure your slabs are computed against.'},
    {h:'Slab-wise Base Tax',p:`Total base tax across all bands = <span class="amt">${fmt(chosen.baseTax)}</span>`,d:'See the slab table on the right for the exact distribution.'},
    {h:'Rebate u/s 87A',p:`Rebate applied: <span class="amt">${fmt(chosen.rebate)}</span>`,d:chosen.regime==='new'?'Up to ₹60,000 rebate if taxable ≤ ₹12,00,000 (new regime).':'Up to ₹12,500 rebate if taxable ≤ ₹5,00,000 (old regime).'},
    {h:'Surcharge (if any)',p:`Surcharge: <span class="amt">${fmt(chosen.surcharge)}</span>`,d:'10% above ₹50L · 15% above ₹1Cr · 25% above ₹2Cr.'},
    {h:'Health & Education Cess (4%)',p:`Cess: <span class="amt">${fmt(chosen.cess)}</span>`,d:'Levied on (tax + surcharge). Goes towards public health & education.'},
    {h:'Final Tax Payable',p:`<span class="amt" style="font-size:18px">${fmt(chosen.total)}</span>`,d:`That's ${pct(chosen.total,oldR.gross).toFixed(2)}% of your gross income.`},
  ];
  $('steps').innerHTML = stepData.map(s=>`<div class="step"><div class="body"><h4>${s.h}</h4><p>${s.p}</p><div class="details">${s.d}</div></div></div>`).join('');
  document.querySelectorAll('.step').forEach(s=>s.onclick=()=>s.classList.toggle('open'));

  // Slab table
  $('slabRegimeLbl').textContent = chosen.regime==='new'?'New':'Old';
  const tbody = $('slabTable').querySelector('tbody');
  tbody.innerHTML = chosen.parts.map(p=>{
    const from = (p.from/100000).toFixed(p.from%100000?1:0)+'L';
    const to = p.to===Infinity?'∞':(p.to/100000).toFixed(p.to%100000?1:0)+'L';
    return `<tr><td>₹${from} – ₹${to}</td><td>${(p.rate*100).toFixed(0)}%</td><td class="tax-cell">${fmt(p.amount)}</td></tr>`;
  }).join('') || '<tr><td colspan="3" style="text-align:center;color:var(--ink-dim)">No taxable income</td></tr>';
  $('slabFoot').textContent = `Base ${fmt(chosen.baseTax)} − Rebate ${fmt(chosen.rebate)} + Surcharge ${fmt(chosen.surcharge)} + Cess ${fmt(chosen.cess)} = ${fmt(chosen.total)}`;

  // Timeline
  const m = Array.from({length:12},(_,k)=>k);
  const baseMonthly = inHand/12;
  const peak = baseMonthly*1.4;
  const bars = m.map(k=>{
    const val = (k===2||k===8) ? peak : baseMonthly;
    return val;
  });
  const max = Math.max(...bars);
  const months = ['A','M','J','J','A','S','O','N','D','J','F','M'];
  $('timelineBars').innerHTML = bars.map((v,k)=>`<div class="tl-bar" title="${fmt(v)}"><div class="fill" style="height:${(v/max*88).toFixed(0)}%"></div><div class="v">${(v/1000).toFixed(0)}k</div><div class="m">${months[k]}</div></div>`).join('');
}

/* ===================== Inputs wiring ===================== */
['salary','other','bonus','free','d80c','d80d','hra','hloan','od','exp','inv','age'].forEach(id=>{
